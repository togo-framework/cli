# togo infra — local/remote Docker deployment for {{.App}}.
terraform {
  required_providers {
    docker = {
      source  = "kreuzwerker/docker"
      version = "~> 3.0"
    }
  }
}

variable "image" {
  type    = string
  default = "{{.App}}:latest"
}

variable "port" {
  type    = number
  default = 8080
}

provider "docker" {}

resource "docker_image" "app" {
  name = var.image
}

resource "docker_container" "app" {
  name  = "{{.App}}"
  image = docker_image.app.image_id
  ports {
    internal = 8080
    external = var.port
  }
  env = ["ADDR=:8080"]
}
